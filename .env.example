# ── App ──────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# ── Azure OpenAI (primary LLM — Phase 2) ─────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ── OpenAI (fallback LLM + TTS) ──────────────────────
OPENAI_API_KEY=
LLM_FALLBACK_ENABLED=true

# ── Azure Speech (primary TTS — Phase 3) ─────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
TTS_DEFAULT_VOICE=en-IN-NeerjaNeural

# ── Storage ──────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/media
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=avatarforge-media

# ── SadTalker (Phase 4) ──────────────────────────────
SADTALKER_CHECKPOINT_DIR=/models/sadtalker
SADTALKER_DEVICE=cpu
