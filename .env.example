# ── App ──────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# ── Azure OpenAI (primary LLM — Phase 2) ─────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ── OpenAI (fallback LLM + TTS) ──────────────────────
OPENAI_API_KEY=
LLM_FALLBACK_ENABLED=true

# ── Azure Speech (primary TTS — Phase 3) ─────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
TTS_DEFAULT_VOICE=en-IN-NeerjaNeural

# ── Storage ──────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/media
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=avatarforge-media

# ── SadTalker (Phase 4) ──────────────────────────────
SADTALKER_CHECKPOINT_DIR=/models/sadtalker
SADTALKER_DEVICE=cpu
AVATAR_INFERENCE_TIMEOUT_SEC=1800

# ── Observability (Phase 6) ──────────────────────────
# MLflow is wired automatically in docker-compose (http://mlflow:5000).
# Langfuse is optional — free tier at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Avatar engines (v1.1) ─────────────────────────────
# Default engine for jobs that don't specify one: sadtalker | hunyuan
AVATAR_DEFAULT_ENGINE=sadtalker
# HunyuanVideo-Avatar server URL. Empty = engine unavailable.
# RunPod example: http://<pod-ip>:<mapped-tcp-port>
HUNYUAN_URL=
# Managed engines — avatar + voice clone via fal. Get a key at fal.ai/dashboard.
FAL_API_KEY=
# Voice cloning (Chatterbox): public URL of a short reference sample of the
# voice to clone. Empty = cloned voice unavailable.
VOICE_CLONE_REFERENCE_URL=
